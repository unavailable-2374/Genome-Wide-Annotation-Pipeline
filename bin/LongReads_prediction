#!/usr/bin/env perl

use strict;
use Getopt::Long;
use Cwd qw/abs_path getcwd cwd/;
use File::Basename;

my $command_line = "$0 " . join(" ", @ARGV);
my $bin_path = dirname($0);
my $software_dir = $bin_path; $software_dir =~ s/\/bin$//;

my $usage_english = &get_usage_english();
if (@ARGV==0){die $usage_english}

my ($long_reads, $long_read_type, $illumina_bam, $cpu, $tmp_dir, $output_alignment_GFF3, $output_raw_GFF3, $intron_info_out, $base_depth_out, $genetic_code, $strand_specific, $homolog_gene_models, $config, $help, $cmdString);
GetOptions(
    "long_reads:s" => \$long_reads,
    "long_read_type:s" => \$long_read_type,
    "illumina_bam:s" => \$illumina_bam,
    "cpu:i" => \$cpu,
    "tmp_dir:s" => \$tmp_dir,
    "output_alignment_GFF3:s" => \$output_alignment_GFF3,
    "output_raw_GFF3:s" => \$output_raw_GFF3,
    "intron_info_out:s" => \$intron_info_out,
    "base_depth_out:s" => \$base_depth_out,
    "genetic_code:i" => \$genetic_code,
    "strand_specific" => \$strand_specific,
    "homolog_gene_models:s" => \$homolog_gene_models,
    "config:s" => \$config,
    "help" => \$help,
);
if ( $help ) { die $usage_english }

# Print command line information to STDERR
my $pwd = `pwd`;
my $programe_name = basename($0);
print STDERR "\n#################### $programe_name | Start ####################\n";
print STDERR "PWD: $pwd" . (localtime) . ": CMD: " . $command_line . "\n";
print STDERR "============================================\n";

########### Parse parameters #################
$genetic_code ||= 1;
$cpu ||= 4;
$long_read_type ||= "pacbio_hifi";

unless ( $long_read_type eq "pacbio_hifi" || $long_read_type eq "nanopore_cdna" || $long_read_type eq "nanopore_drna" ) {
    die "Error: --long_read_type must be one of: pacbio_hifi, nanopore_cdna, nanopore_drna\n";
}

unless ( $long_reads ) {
    die "Error: --long_reads parameter is required. Please provide FLNC FASTQ/BAM files (comma-separated).\n";
}

# Use absolute paths for all input files
my $input_genome = abs_path($ARGV[0]);
die "Error: Please provide a genome FASTA file as positional argument.\n" unless $input_genome;
die "Error: Genome file $input_genome does not exist.\n" unless -e $input_genome;

$homolog_gene_models = abs_path($homolog_gene_models) if $homolog_gene_models;
$output_alignment_GFF3 = abs_path($output_alignment_GFF3) if $output_alignment_GFF3;
$output_raw_GFF3 = abs_path($output_raw_GFF3) if $output_raw_GFF3;
$intron_info_out = abs_path($intron_info_out) if defined $intron_info_out;
$base_depth_out = abs_path($base_depth_out) if defined $base_depth_out;
$illumina_bam = abs_path($illumina_bam) if $illumina_bam;

# Process long read input files to absolute paths
my @long_read_files;
foreach my $f ( split /,/, $long_reads ) {
    $f =~ s/^\s+//; $f =~ s/\s+$//;
    my $abs_f = abs_path($f);
    die "Error: Long read file $f does not exist.\n" unless -e $abs_f;
    push @long_read_files, $abs_f;
}
my $long_reads_abs = join(" ", @long_read_files);

# Parse config file if provided
my %config;
if ($config) {
    $config = abs_path($config);
    open IN, $config or die "Can not open file $config, $!\n";
    my $tag;
    while (<IN>) {
        next if m/^#/;
        next if m/^\s*$/;
        s/^\s+//;
        s/\n/ /;
        if (/\[(.*)\]/) { $tag = $1; delete $config{$1}; }
        else { $config{$tag} .= $_; }
    }
    close IN;
}

# Prepare temporary directory
my $date = `date +%Y%m%d%H%M%S`; chomp($date);
$tmp_dir ||= "LongReads_prediction_tmp";
$tmp_dir = abs_path($tmp_dir);
mkdir $tmp_dir unless -e $tmp_dir;
chdir $tmp_dir; print STDERR "\nPWD: $tmp_dir\n";


# Step a: minimap2 alignment
print STDERR "\nStep a: Aligning long reads to genome by minimap2 " . "(" . (localtime) . ")" . "\n";
mkdir "$tmp_dir/a.minimap2" unless -e "$tmp_dir/a.minimap2";
unless (-e "$tmp_dir/a.minimap2.ok") {
    chdir "$tmp_dir/a.minimap2"; print STDERR "PWD: $tmp_dir/a.minimap2\n";

    # Select minimap2 parameters based on long read type
    my $minimap2_params;
    if ( $long_read_type eq "pacbio_hifi" ) {
        $minimap2_params = "-ax splice:hq -uf --secondary=no";
    }
    elsif ( $long_read_type eq "nanopore_cdna" ) {
        $minimap2_params = "-ax splice --secondary=no";
    }
    elsif ( $long_read_type eq "nanopore_drna" ) {
        $minimap2_params = "-ax splice -uf -k14 --secondary=no";
    }

    $cmdString = "minimap2 $minimap2_params -t $cpu $input_genome $long_reads_abs | samtools sort -\@ $cpu -o sorted.bam";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    $cmdString = "samtools index -\@ $cpu sorted.bam";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    chdir "$tmp_dir";
    open OUT, ">", "$tmp_dir/a.minimap2.ok" or die $!; close OUT;
}
else {
    print STDERR "Skip Step a for the file a.minimap2.ok exists\n";
}


# Step b: IsoQuant transcript discovery
print STDERR "\nStep b: IsoQuant transcript discovery " . "(" . (localtime) . ")" . "\n";
mkdir "$tmp_dir/b.isoquant" unless -e "$tmp_dir/b.isoquant";
unless (-e "$tmp_dir/b.isoquant.ok") {
    chdir "$tmp_dir/b.isoquant"; print STDERR "PWD: $tmp_dir/b.isoquant\n";

    # Determine IsoQuant data type
    my $isoquant_data_type;
    if ( $long_read_type eq "pacbio_hifi" ) {
        $isoquant_data_type = "pacbio_ccs";
    }
    else {
        $isoquant_data_type = "nanopore";
    }

    $cmdString = "isoquant.py --reference $input_genome --bam $tmp_dir/a.minimap2/sorted.bam --data_type $isoquant_data_type --complete_genedb --threads $cpu --output $tmp_dir/b.isoquant/isoquant_out --prefix lr";

    # Add illumina BAM for junction correction if provided
    if ( $illumina_bam ) {
        $cmdString .= " --illumina_bam $illumina_bam";
    }

    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    chdir "$tmp_dir";
    open OUT, ">", "$tmp_dir/b.isoquant.ok" or die $!; close OUT;
}
else {
    print STDERR "Skip Step b for the file b.isoquant.ok exists\n";
}


# Step c: SQANTI3 quality control and filtering
print STDERR "\nStep c: SQANTI3 quality control and filtering " . "(" . (localtime) . ")" . "\n";
mkdir "$tmp_dir/c.sqanti3" unless -e "$tmp_dir/c.sqanti3";
unless (-e "$tmp_dir/c.sqanti3.ok") {
    chdir "$tmp_dir/c.sqanti3"; print STDERR "PWD: $tmp_dir/c.sqanti3\n";

    # Find the IsoQuant GTF output - IsoQuant uses different output paths depending on version
    my $isoquant_gtf = "$tmp_dir/b.isoquant/isoquant_out/lr.transcript_models.gtf";
    unless (-e $isoquant_gtf) {
        # Try alternative paths that IsoQuant may use
        my @candidates = glob("$tmp_dir/b.isoquant/isoquant_out/lr*/lr.transcript_models.gtf");
        if (@candidates) {
            $isoquant_gtf = $candidates[0];
        }
        else {
            @candidates = glob("$tmp_dir/b.isoquant/isoquant_out/*.transcript_models.gtf");
            if (@candidates) {
                $isoquant_gtf = $candidates[0];
            }
            else {
                die "Error: Cannot find IsoQuant transcript models GTF output.\n";
            }
        }
    }
    print STDERR (localtime) . ": Using IsoQuant GTF: $isoquant_gtf\n";

    # Run SQANTI3 QC
    $cmdString = "sqanti3_qc.py $isoquant_gtf $input_genome --output sqanti3_out --dir $tmp_dir/c.sqanti3/sqanti3_dir -t $cpu";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    # Run SQANTI3 rules-based filter
    $cmdString = "sqanti3_filter.py rules $tmp_dir/c.sqanti3/sqanti3_dir/sqanti3_out_classification.txt --isoforms $tmp_dir/c.sqanti3/sqanti3_dir/sqanti3_out_corrected.gtf --gtf $tmp_dir/c.sqanti3/sqanti3_dir/sqanti3_out_corrected.gtf -o filtered";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    chdir "$tmp_dir";
    open OUT, ">", "$tmp_dir/c.sqanti3.ok" or die $!; close OUT;
}
else {
    print STDERR "Skip Step c for the file c.sqanti3.ok exists\n";
}


# Step d: TransDecoder ORF prediction
print STDERR "\nStep d: TransDecoder ORF prediction " . "(" . (localtime) . ")" . "\n";
mkdir "$tmp_dir/d.transdecoder" unless -e "$tmp_dir/d.transdecoder";
unless (-e "$tmp_dir/d.transdecoder.ok") {
    chdir "$tmp_dir/d.transdecoder"; print STDERR "PWD: $tmp_dir/d.transdecoder\n";

    # Find the filtered GTF from SQANTI3
    my $filtered_gtf = "$tmp_dir/c.sqanti3/filtered.filtered.gtf";
    unless (-e $filtered_gtf) {
        # Try alternative names SQANTI3 filter may produce
        my @candidates = glob("$tmp_dir/c.sqanti3/filtered*.gtf");
        if (@candidates) {
            $filtered_gtf = $candidates[0];
        }
        else {
            die "Error: Cannot find SQANTI3 filtered GTF output.\n";
        }
    }
    print STDERR (localtime) . ": Using filtered GTF: $filtered_gtf\n";

    # Extract transcript sequences from filtered GTF
    $cmdString = "gffread $filtered_gtf -g $input_genome -w $tmp_dir/d.transdecoder/filtered_transcripts.fa";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    # TransDecoder: find long ORFs
    $cmdString = "TransDecoder.LongOrfs -t $tmp_dir/d.transdecoder/filtered_transcripts.fa -O $tmp_dir/d.transdecoder --genetic_code $genetic_code";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    # TransDecoder: predict likely coding regions
    $cmdString = "TransDecoder.Predict -t $tmp_dir/d.transdecoder/filtered_transcripts.fa -O $tmp_dir/d.transdecoder --single_best_only --genetic_code $genetic_code";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    # Convert filtered GTF to alignment GFF3 for TransDecoder utility
    $cmdString = "TransDecoder.Util.gtf_to_alignment_gff3.pl $filtered_gtf > $tmp_dir/d.transdecoder/transcript_alignments.gff3";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    # Map transcript-based ORF coordinates back to genome coordinates
    # TransDecoder output location varies: check both -O output dir and default location
    my $transdecoder_gff3 = "$tmp_dir/d.transdecoder/filtered_transcripts.fa.transdecoder.gff3";
    unless (-e $transdecoder_gff3) {
        $transdecoder_gff3 = "filtered_transcripts.fa.transdecoder.gff3";
        unless (-e $transdecoder_gff3) {
            my @candidates = glob("$tmp_dir/d.transdecoder/*.transdecoder.gff3");
            if (@candidates) {
                $transdecoder_gff3 = $candidates[0];
            }
            else {
                die "Error: Cannot find TransDecoder GFF3 output.\n";
            }
        }
    }

    $cmdString = "TransDecoder.Util.cdna_alignment_orf_to_genome_orf.pl $transdecoder_gff3 $tmp_dir/d.transdecoder/transcript_alignments.gff3 $tmp_dir/d.transdecoder/filtered_transcripts.fa > $tmp_dir/d.transdecoder/genome_based_orf.gff3";
    print STDERR (localtime) . ": CMD: $cmdString\n";
    system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

    chdir "$tmp_dir";
    open OUT, ">", "$tmp_dir/d.transdecoder.ok" or die $!; close OUT;
}
else {
    print STDERR "Skip Step d for the file d.transdecoder.ok exists\n";
}


# Step e: Post-processing
print STDERR "\nStep e: Post-processing and output " . "(" . (localtime) . ")" . "\n";
mkdir "$tmp_dir/e.postprocessing" unless -e "$tmp_dir/e.postprocessing";
chdir "$tmp_dir/e.postprocessing"; print STDERR "PWD: $tmp_dir/e.postprocessing\n";

# e.1: Parse genome_based_orf.gff3 from TransDecoder into GETA-format GFF3
unless (-e "$tmp_dir/e.postprocessing.ok") {

    # Read genome sequences for integrity checking
    my %genome_seq;
    open IN, $input_genome or die "Error: Can not open file $input_genome, $!";
    my $seq_id;
    while (<IN>) {
        chomp;
        if (m/^>(\S+)/) {
            $seq_id = $1;
        }
        else {
            $genome_seq{$seq_id} .= uc($_);
        }
    }
    close IN;

    # Determine start and stop codons based on genetic code
    my ($start_codon_str, $stop_codon_str) = &get_codons_for_genetic_code($genetic_code);
    my %start_codons;
    my %stop_codons;
    foreach (split /,/, $start_codon_str) { $start_codons{$_} = 1; }
    foreach (split /,/, $stop_codon_str) { $stop_codons{$_} = 1; }

    # Parse TransDecoder genome-based GFF3
    my $td_gff3 = "$tmp_dir/d.transdecoder/genome_based_orf.gff3";
    die "Error: Cannot find TransDecoder genome-based ORF GFF3: $td_gff3\n" unless -e $td_gff3;

    # Parse the TransDecoder output into gene models
    # TransDecoder genome-based GFF3 has: gene, mRNA, exon, CDS features
    my (%gene_info, %gene_order, @gene_ids);
    my $gene_count = 0;
    open IN, $td_gff3 or die "Error: Can not open file $td_gff3, $!";
    my (%td_genes, %td_mRNAs, %td_CDS, %td_exons, %mRNA_to_gene, %gene_chr, %gene_strand);
    while (<IN>) {
        chomp;
        next if /^#/;
        next if /^\s*$/;
        my @F = split /\t/;
        next unless @F >= 9;
        my ($chr, $source, $feature, $start, $end, $score, $strand, $phase, $attr) = @F;

        if ($feature eq "gene") {
            my ($id) = $attr =~ /ID=([^;\s]+)/;
            $td_genes{$id} = {
                chr => $chr, source => $source, start => $start, end => $end,
                score => $score, strand => $strand, phase => $phase, attr => $attr,
                mRNAs => [],
            };
            $gene_chr{$id} = $chr;
            $gene_strand{$id} = $strand;
            $gene_count++;
            $gene_order{$id} = $gene_count;
            push @gene_ids, $id;
        }
        elsif ($feature eq "mRNA") {
            my ($id) = $attr =~ /ID=([^;\s]+)/;
            my ($parent) = $attr =~ /Parent=([^;\s]+)/;
            $td_mRNAs{$id} = {
                chr => $chr, source => $source, start => $start, end => $end,
                score => $score, strand => $strand, phase => $phase, attr => $attr,
                parent => $parent,
            };
            push @{$td_genes{$parent}{mRNAs}}, $id if exists $td_genes{$parent};
            $mRNA_to_gene{$id} = $parent;
            $td_CDS{$id} = [];
            $td_exons{$id} = [];
        }
        elsif ($feature eq "CDS") {
            my ($parent) = $attr =~ /Parent=([^;\s]+)/;
            push @{$td_CDS{$parent}}, { chr => $chr, start => $start, end => $end, strand => $strand, phase => $phase };
        }
        elsif ($feature eq "exon") {
            my ($parent) = $attr =~ /Parent=([^;\s]+)/;
            push @{$td_exons{$parent}}, { chr => $chr, start => $start, end => $end, strand => $strand };
        }
    }
    close IN;

    # Build GETA-format GFF3 gene models
    my %gff3_output;  # chr => [ gene_blocks ]
    my $lr_gene_num = 0;

    foreach my $gene_id ( sort { $gene_order{$a} <=> $gene_order{$b} } @gene_ids ) {
        my $gene = $td_genes{$gene_id};
        next unless $gene && @{$gene->{mRNAs}};

        $lr_gene_num++;
        my $new_gene_id = sprintf("LongReads%05d", $lr_gene_num);
        my $chr = $gene->{chr};
        my $strand = $gene->{strand};

        my ($gene_start, $gene_end) = ($gene->{start}, $gene->{end});

        my @mRNA_blocks;
        my $mRNA_count = 0;

        foreach my $mRNA_id ( @{$gene->{mRNAs}} ) {
            $mRNA_count++;
            my $mRNA = $td_mRNAs{$mRNA_id};
            my $new_mRNA_id = "${new_gene_id}.t${mRNA_count}";

            # Sort CDS by position
            my @cds = sort { $a->{start} <=> $b->{start} } @{$td_CDS{$mRNA_id}};
            next unless @cds;

            # Sort exons by position; if no exons from TransDecoder, generate from CDS
            my @exons;
            if ( $td_exons{$mRNA_id} && @{$td_exons{$mRNA_id}} ) {
                @exons = sort { $a->{start} <=> $b->{start} } @{$td_exons{$mRNA_id}};
            }
            else {
                @exons = map { { chr => $_->{chr}, start => $_->{start}, end => $_->{end}, strand => $_->{strand} } } @cds;
            }

            # Determine mRNA boundaries
            my $mRNA_start = $exons[0]->{start};
            my $mRNA_end = $exons[-1]->{end};
            $mRNA_start = $cds[0]->{start} if $cds[0]->{start} < $mRNA_start;
            $mRNA_end = $cds[-1]->{end} if $cds[-1]->{end} > $mRNA_end;

            # Update gene boundaries
            $gene_start = $mRNA_start if $mRNA_start < $gene_start;
            $gene_end = $mRNA_end if $mRNA_end > $gene_end;

            # Check ORF integrity (start and stop codons)
            my $integrity = &check_integrity(\@cds, $strand, \%genome_seq, $chr, \%start_codons, \%stop_codons);

            # Calculate CDS length (total coding length)
            my $cds_length = 0;
            foreach my $c (@cds) { $cds_length += ($c->{end} - $c->{start} + 1); }

            # Calculate total exon/transcript length
            my $transcript_length = 0;
            foreach my $e (@exons) { $transcript_length += ($e->{end} - $e->{start} + 1); }
            $transcript_length = $cds_length if $transcript_length == 0;

            my $orf_ratio = sprintf("%.1f", $cds_length / $transcript_length * 100);

            # Build mRNA attribute
            my $mRNA_attr = "ID=$new_mRNA_id;Parent=$new_gene_id;Integrity=$integrity;Form=1_${orf_ratio}%";

            # Build GFF3 lines for this mRNA
            my @lines;
            push @lines, join("\t", $chr, "LongReads", "mRNA", $mRNA_start, $mRNA_end, ".", $strand, ".", $mRNA_attr);

            # Recalculate CDS phases
            my @cds_ordered = ($strand eq "+") ? @cds : reverse @cds;
            my $cumulative_phase = 0;
            my @cds_with_phase;
            foreach my $c (@cds_ordered) {
                my $phase = $cumulative_phase % 3;
                $phase = (3 - $phase) % 3;
                push @cds_with_phase, { %$c, phase => $phase };
                $cumulative_phase += ($c->{end} - $c->{start} + 1);
            }
            # Restore original order for output (sorted by position)
            if ($strand eq "-") {
                @cds_with_phase = reverse @cds_with_phase;
            }

            foreach my $c (@cds_with_phase) {
                push @lines, join("\t", $chr, "LongReads", "CDS", $c->{start}, $c->{end}, ".", $strand, $c->{phase}, "Parent=$new_mRNA_id");
            }

            foreach my $e (@exons) {
                push @lines, join("\t", $chr, "LongReads", "exon", $e->{start}, $e->{end}, ".", $strand, ".", "Parent=$new_mRNA_id");
            }

            push @mRNA_blocks, {
                lines => \@lines,
                integrity => $integrity,
                orf_ratio => $orf_ratio,
                cds_length => $cds_length,
            };
        }

        next unless @mRNA_blocks;

        # Build gene line
        my $gene_attr = "ID=$new_gene_id";
        my $gene_line = join("\t", $chr, "LongReads", "gene", $gene_start, $gene_end, ".", $strand, ".", $gene_attr);

        my $gene_block = $gene_line . "\n";
        foreach my $mb (@mRNA_blocks) {
            $gene_block .= join("\n", @{$mb->{lines}}) . "\n";
        }

        push @{$gff3_output{$chr}}, {
            start => $gene_start,
            end => $gene_end,
            block => $gene_block,
            gene_id => $new_gene_id,
            integrity => $mRNA_blocks[0]->{integrity},
            orf_ratio => $mRNA_blocks[0]->{orf_ratio},
            cds_length => $mRNA_blocks[0]->{cds_length},
        };
    }

    # e.2: Generate intron.txt from the BAM alignment
    if ( defined $intron_info_out ) {
        print STDERR (localtime) . ": Generating intron information from BAM alignment\n";
        &generate_intron_info("$tmp_dir/a.minimap2/sorted.bam", $intron_info_out, \%genome_seq);
    }

    # e.3: Generate base_depth.txt from the BAM alignment using samtools depth
    if ( defined $base_depth_out ) {
        print STDERR (localtime) . ": Generating base depth information from BAM alignment\n";
        &generate_base_depth("$tmp_dir/a.minimap2/sorted.bam", $base_depth_out);
    }

    # e.4: Write output alignment GFF3 (TransDecoder raw genome-based ORF GFF3)
    if ( $output_alignment_GFF3 ) {
        $cmdString = "cp $tmp_dir/d.transdecoder/transcript_alignments.gff3 $output_alignment_GFF3";
        print STDERR (localtime) . ": CMD: $cmdString\n";
        system("$cmdString") == 0 or die "failed to execute: $cmdString\n";
    }

    # e.5: Use GFF3Clear to clean up the gene models
    # First, write the raw GETA-format GFF3
    open OUT, ">", "$tmp_dir/e.postprocessing/lr_raw_models.gff3" or die "Error: Can not create file lr_raw_models.gff3, $!";
    foreach my $chr ( sort keys %gff3_output ) {
        my @genes = sort { $a->{start} <=> $b->{start} } @{$gff3_output{$chr}};
        foreach my $g (@genes) {
            print OUT $g->{block} . "\n";
        }
    }
    close OUT;

    # e.6: Use GFF3_merging_and_removing_redundancy to remove redundant models, then GFF3Clear
    my @cmdStrings;
    push @cmdStrings, "$bin_path/GFF3_merging_and_removing_redundancy_Parallel --cpu $cpu $input_genome --first_file_score 0.0 $tmp_dir/e.postprocessing/lr_raw_models.gff3 > $tmp_dir/e.postprocessing/lr_merged.gff3 2> /dev/null";
    push @cmdStrings, "$bin_path/GFF3Clear --GFF3_source LongReads --genome $input_genome --gene_prefix lr --no_attr_add $tmp_dir/e.postprocessing/lr_merged.gff3 > $tmp_dir/e.postprocessing/lr_cleaned.gff3 2> /dev/null";
    push @cmdStrings, "rm -rf $tmp_dir/e.postprocessing/lr_merged.gff3";

    &execute_cmds(@cmdStrings, "$tmp_dir/e.GFF3Clear.ok");

    # e.7: If --homolog_gene_models provided, fill incomplete models
    my @codon_info = &codon_table();
    my %start_codon_table = %{$codon_info[1]};
    my %stop_codon_table = %{$codon_info[2]};
    my $start_codon_list = join ",", sort keys %start_codon_table;
    my $stop_codon_list = join ",", sort keys %stop_codon_table;

    if ( $homolog_gene_models ) {
        $cmdString = "rm -rf $tmp_dir/e.FillingByHomolog.ok $tmp_dir/e.fillingEnds.ok";
        &execute_cmds($cmdString, "$tmp_dir/e.FillingByHomolog.yes");

        $cmdString = "$bin_path/GFF3_filling_gene_models_Parallel --cpu $cpu --tmp_dir $tmp_dir/e.postprocessing/FillingByHomolog --ouput_filling_detail_tab $tmp_dir/e.postprocessing/FillingByHomolog.tab --start_codon $start_codon_list --stop_codon $stop_codon_list --attribute_for_filling_complete Filled_by_homolog=True $input_genome $tmp_dir/e.postprocessing/lr_cleaned.gff3 $homolog_gene_models > $tmp_dir/e.postprocessing/lr_filledByHomolog.gff3";
        &execute_cmds($cmdString, "$tmp_dir/e.FillingByHomolog.ok");
    }
    else {
        $cmdString = "cp -a $tmp_dir/e.postprocessing/lr_cleaned.gff3 $tmp_dir/e.postprocessing/lr_filledByHomolog.gff3";
        &execute_cmds($cmdString, "$tmp_dir/e.FillingByHomolog.ok");
    }

    # e.8: Force-fill ends of incomplete gene models
    $cmdString = "$bin_path/fillingEndsOfGeneModels --start_codon $start_codon_list --stop_codon $stop_codon_list $input_genome $tmp_dir/e.postprocessing/lr_filledByHomolog.gff3 > $tmp_dir/e.postprocessing/lr_fillEnd.gff3 2> $tmp_dir/e.postprocessing/fillingEndsOfGeneModels.log";
    &execute_cmds($cmdString, "$tmp_dir/e.fillingEnds.ok");

    # e.9: Output raw GFF3 (before force-filling) if requested
    if ( $output_raw_GFF3 ) {
        open IN, "$tmp_dir/e.postprocessing/lr_filledByHomolog.gff3" or die "Error: Can not open file lr_filledByHomolog.gff3, $!";
        my $raw_gff3_content = join "", <IN>;
        close IN;
        open OUT, ">", $output_raw_GFF3 or die "Error: Can not create file $output_raw_GFF3, $!";
        foreach ( split /\n\n/, $raw_gff3_content ) {
            if (m/Integrity=complete/ && m/Form=.*?_([\d\.]+)\%/ && $1 >= 50) {
                s/(\tgene\t.*ID=[^;]+)/$1;Type=excellent_gene_models_predicted_by_LongReads/;
            }
            print OUT "$_\n\n";
        }
        close OUT;
    }

    chdir "$tmp_dir";
    open OUT, ">", "$tmp_dir/e.postprocessing.ok" or die $!; close OUT;
}
else {
    print STDERR "Skip Step e for the file e.postprocessing.ok exists\n";
}


# Final output: classify gene models and output to STDOUT
print STDERR "\nFinal: Dividing gene models into 4 classes " . "(" . (localtime) . ")" . "\n";
print STDERR "Class A (Excellent gene models): Complete gene models predicted by long reads, or filled in by homolog, meanwhile the ORF occupies at least 50% of the transcript sequence.\n";
print STDERR "Class B (Good gene models): Other complete gene models predicted by long reads, or filled in by homolog.\n";
print STDERR "Class C (Fair gene models): Complete gene models after enforcing padding at the 5' or 3' end of the gene model.\n";
print STDERR "Class D (Poor gene models): Incomplete gene models.\n";

open IN, "$tmp_dir/e.postprocessing/lr_fillEnd.gff3" or die "Can not open file lr_fillEnd.gff3, $!";
my ( $num0, $num1, $num2, $num3, $num4 ) = (0, 0, 0, 0, 0);
$/ = "\n\n";
while (<IN>) {
    $num0 ++;
    if (m/Integrity=complete/ or m/Filled_by_homolog=True/) {
        if (m/Form=.*?_([\d\.]+)\%/ && $1 >= 50) {
            s/(\tgene\t.*ID=[^;]+)/$1;Type=excellent_gene_models_predicted_by_LongReads/;
            $num1 ++;
        }
        else {
            s/(\tgene\t.*ID=[^;]+)/$1;Type=good_gene_models_predicted_by_LongReads/;
            $num2 ++;
        }
    }
    elsif ( m/Filling2Complete=True/ ) {
        s/(\tgene\t.*ID=[^;]+)/$1;Type=fair_gene_models_predicted_by_LongReads/;
        $num3 ++;
    }
    elsif ( m/Filling2Uncomplete=True/ ) {
        s/(\tgene\t.*ID=[^;]+)/$1;Type=poor_gene_models_predicted_by_LongReads/;
        $num4 ++;
    }
    print;
}
close IN;
$/ = "\n";
print STDERR "\nFinally, total $num0 gene models were divided into 4 classes : A, $num1; B, $num2; C, $num3; D, $num4.\n";

print STDERR "============================================\n";
print STDERR "$programe_name complete successfully! " . "(" . (localtime) . ")" . "\n\n";
print STDERR "#################### $programe_name | End ####################\n";


###############################################################################
# Subroutines
###############################################################################

# Execute commands with .ok checkpoint file support
sub execute_cmds {
    my $ok_file = pop @_;

    if ( -e $ok_file ) {
        foreach ( @_ ) {
            print STDERR "CMD(Skipped): $_\n";
        }
    }
    else {
        foreach ( @_ ) {
            print STDERR (localtime) . ": CMD: $_\n";
            system($_) == 0 or die "failed to execute: $_\n";
        }
        open OUT, ">", "$ok_file" or die $!; close OUT;
    }

    return 1;
}


# Check ORF integrity: does the CDS have proper start and stop codons?
sub check_integrity {
    my ($cds_ref, $strand, $genome_ref, $chr, $start_codons_ref, $stop_codons_ref) = @_;

    my @cds = sort { $a->{start} <=> $b->{start} } @$cds_ref;
    return "incomplete" unless @cds;

    my $seq = $genome_ref->{$chr};
    return "incomplete" unless $seq;

    my ($has_start, $has_stop) = (0, 0);

    if ($strand eq "+") {
        # Check start codon at the beginning of the first CDS
        my $start_pos = $cds[0]->{start} - 1;  # 0-based
        if ($start_pos >= 0 && $start_pos + 3 <= length($seq)) {
            my $codon = substr($seq, $start_pos, 3);
            $has_start = 1 if exists $start_codons_ref->{$codon};
        }
        # Check stop codon at the end of the last CDS
        my $stop_pos = $cds[-1]->{end} - 3;  # last 3 bases of CDS (0-based)
        if ($stop_pos >= 0 && $stop_pos + 3 <= length($seq)) {
            my $codon = substr($seq, $stop_pos, 3);
            $has_stop = 1 if exists $stop_codons_ref->{$codon};
        }
    }
    else {
        # Negative strand: start codon at the end of the last CDS (reverse complement)
        my $start_pos = $cds[-1]->{end} - 3;  # 0-based
        if ($start_pos >= 0 && $start_pos + 3 <= length($seq)) {
            my $codon = &reverse_complement(substr($seq, $start_pos, 3));
            $has_start = 1 if exists $start_codons_ref->{$codon};
        }
        # Stop codon at the beginning of the first CDS (reverse complement)
        my $stop_pos = $cds[0]->{start} - 1;  # 0-based
        if ($stop_pos >= 0 && $stop_pos + 3 <= length($seq)) {
            my $codon = &reverse_complement(substr($seq, $stop_pos, 3));
            $has_stop = 1 if exists $stop_codons_ref->{$codon};
        }
    }

    if ($has_start && $has_stop) {
        return "complete";
    }
    elsif ($has_start && !$has_stop) {
        return "3prime_partial";
    }
    elsif (!$has_start && $has_stop) {
        return "5prime_partial";
    }
    else {
        return "internal";
    }
}


sub reverse_complement {
    my $seq = shift;
    $seq = reverse $seq;
    $seq =~ tr/ATCGatcg/TAGCtagc/;
    return $seq;
}


# Generate intron information from BAM file
# Output format: 7 columns (Transcript_region, Chromosome, Strand, Intron_start, Intron_end, Intron_depth, Median_base_depth_in_intron)
sub generate_intron_info {
    my ($bam_file, $output_file, $genome_ref) = @_;

    # Use samtools to extract intron information from CIGAR strings
    # Parse BAM file and extract splice junctions (N operations in CIGAR)
    my %intron_counts;  # "chr\tstrand\tstart\tend" => count

    open BAM, "samtools view $bam_file |" or die "Error: Cannot run samtools view on $bam_file\n";
    while (<BAM>) {
        chomp;
        my @fields = split /\t/;
        my ($flag, $chr, $pos, $cigar) = ($fields[1], $fields[2], $fields[3], $fields[5]);

        next if $flag & 4;  # skip unmapped
        next if $cigar eq "*";

        # Determine strand from XS tag if available, otherwise use flag
        my $strand = ".";
        if (/XS:A:([+-])/) {
            $strand = $1;
        }
        elsif ($flag & 16) {
            $strand = "-";
        }
        else {
            $strand = "+";
        }

        # Parse CIGAR to find introns (N operations)
        my $ref_pos = $pos;
        while ($cigar =~ /(\d+)([MIDNSHP=X])/g) {
            my ($len, $op) = ($1, $2);
            if ($op eq "N") {
                my $intron_start = $ref_pos;
                my $intron_end = $ref_pos + $len - 1;
                my $key = "$chr\t$strand\t$intron_start\t$intron_end";
                $intron_counts{$key}++;
                $ref_pos += $len;
            }
            elsif ($op eq "M" || $op eq "D" || $op eq "=" || $op eq "X") {
                $ref_pos += $len;
            }
            # S, H, I, P do not consume reference
        }
    }
    close BAM;

    # Write intron info file
    open OUT, ">", $output_file or die "Error: Can not create file $output_file, $!";
    print OUT "#Transcript_region\tChromosome\tStrand\tIntron_start\tIntron_end\tIntron_depth\tMedian_base_depth_in_intron\n";
    foreach my $key (sort keys %intron_counts) {
        my ($chr, $strand, $start, $end) = split /\t/, $key;
        my $depth = $intron_counts{$key};
        # Median base depth in the intron region set to 0 as a placeholder
        # (accurate calculation would require samtools depth for each intron, which is expensive)
        # Use a simple approach: the intron depth itself as proxy
        my $median_depth = 0;
        print OUT "LongReads_$chr:$start-$end\t$chr\t$strand\t$start\t$end\t$depth\t$median_depth\n";
    }
    close OUT;
    print STDERR (localtime) . ": Intron info written to $output_file\n";
}


# Generate base depth file from BAM
sub generate_base_depth {
    my ($bam_file, $output_file) = @_;

    # Use samtools depth to generate per-base coverage
    # samtools depth outputs: chr, pos, depth
    # We need to add strand info. For simplicity with long reads, we report depth on both strands combined
    # and assign strand based on read direction.

    # First, generate depth for forward reads and reverse reads separately
    # For simplicity, use samtools depth on the whole BAM and assign "+" strand
    # This matches the GETA convention where strand info is simplified

    open OUT, ">", $output_file or die "Error: Can not create file $output_file, $!";
    print OUT "#Chromosome\tStrand\tPosition\tDepth\n";

    # Generate depth using samtools depth
    open DEPTH, "samtools depth -a $bam_file |" or die "Error: Cannot run samtools depth\n";
    while (<DEPTH>) {
        chomp;
        my ($chr, $pos, $depth) = split /\t/;
        next unless $depth > 0;
        print OUT "$chr\t+\t$pos\t$depth\n";
    }
    close DEPTH;
    close OUT;
    print STDERR (localtime) . ": Base depth info written to $output_file\n";
}


# Get start and stop codons for a given genetic code
sub get_codons_for_genetic_code {
    my $code = shift;
    my $start = "ATG";
    my $stop = "TAA,TAG,TGA";

    if ($code == 1) {
        # Standard
    }
    elsif ($code == 2) {
        $start = "ATG,ATA,ATT,ATC,GTG";
        $stop = "TAA,TAG,AGA,AGG";
    }
    elsif ($code == 3) {
        $start = "ATG,ATA,GTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 4) {
        $start = "ATG,ATA,ATT,ATC,GTG,CTG,TTA,TTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 5) {
        $start = "ATG,ATA,ATT,ATC,GTG,TTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 6) {
        $stop = "TGA";
    }
    elsif ($code == 9) {
        $start = "ATG,GTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 10) {
        $stop = "TAA,TAG";
    }
    elsif ($code == 11) {
        $start = "ATG,ATA,ATT,ATC,GTG,CTG,TTG";
    }
    elsif ($code == 12) {
        $start = "ATG,CTG";
    }
    elsif ($code == 13) {
        $start = "ATG,ATA,GTG,TTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 14) {
        $stop = "TAG";
    }
    elsif ($code == 16) {
        $stop = "TAA,TGA";
    }
    elsif ($code == 21) {
        $start = "ATG,GTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 22) {
        $stop = "TAA,TGA";
    }
    elsif ($code == 23) {
        $start = "ATG,ATT,GTG";
        $stop = "TAA,TAG,TGA,TTA";
    }
    elsif ($code == 24) {
        $start = "ATG,GTG,CTG,TTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 25) {
        $start = "ATG,GTG,TTG";
        $stop = "TAA,TAG";
    }
    elsif ($code == 26) {
        $start = "ATG,GTG,TTG";
    }
    elsif ($code == 27) {
        $stop = "TGA";
    }
    elsif ($code == 29) {
        $stop = "TGA";
    }
    elsif ($code == 30) {
        $stop = "TGA";
    }
    elsif ($code == 31) {
        $stop = "TAA,TAG";
    }
    elsif ($code == 33) {
        $stop = "TAG,AGA,AGG";
    }

    return ($start, $stop);
}


# Codon table subroutine (matching NGSReads_prediction pattern)
sub codon_table {
    my %code = (
        "TTT" => "F", "TTC" => "F", "TTA" => "L", "TTG" => "L",
        "TCT" => "S", "TCC" => "S", "TCA" => "S", "TCG" => "S",
        "TAT" => "Y", "TAC" => "Y", "TAA" => "X", "TAG" => "X",
        "TGT" => "C", "TGC" => "C", "TGA" => "X", "TGG" => "W",
        "CTT" => "L", "CTC" => "L", "CTA" => "L", "CTG" => "L",
        "CCT" => "P", "CCC" => "P", "CCA" => "P", "CCG" => "P",
        "CAT" => "H", "CAC" => "H", "CAA" => "Q", "CAG" => "Q",
        "CGT" => "R", "CGC" => "R", "CGA" => "R", "CGG" => "R",
        "ATT" => "I", "ATC" => "I", "ATA" => "I", "ATG" => "M",
        "ACT" => "T", "ACC" => "T", "ACA" => "T", "ACG" => "T",
        "AAT" => "N", "AAC" => "N", "AAA" => "K", "AAG" => "K",
        "AGT" => "S", "AGC" => "S", "AGA" => "R", "AGG" => "R",
        "GTT" => "V", "GTC" => "V", "GTA" => "V", "GTG" => "V",
        "GCT" => "A", "GCC" => "A", "GCA" => "A", "GCG" => "A",
        "GAT" => "D", "GAC" => "D", "GAA" => "E", "GAG" => "E",
        "GGT" => "G", "GGC" => "G", "GGA" => "G", "GGG" => "G",
    );
    my %start_codon;
    $start_codon{"ATG"} = 1;
    if ( $genetic_code == 1 ) {
        # The Standard Code
    }
    elsif ( $genetic_code == 2 ) {
        $code{"AGA"} = "X"; $code{"AGG"} = "X"; $code{"ATA"} = "M"; $code{"TGA"} = "W";
        $start_codon{"ATA"} = 1; $start_codon{"ATT"} = 1; $start_codon{"ATC"} = 1; $start_codon{"GTG"} = 1;
    }
    elsif ( $genetic_code == 3 ) {
        $code{"ATA"} = "M"; $code{"CTT"} = "T"; $code{"CTC"} = "T"; $code{"CTA"} = "T"; $code{"CTG"} = "T"; $code{"TGA"} = "W";
        $start_codon{"ATA"} = 1; $start_codon{"GTG"} = 1;
    }
    elsif ( $genetic_code == 4 ) {
        $code{"TGA"} = "W";
        $start_codon{"ATA"} = 1; $start_codon{"ATT"} = 1; $start_codon{"ATC"} = 1; $start_codon{"GTG"} = 1; $start_codon{"CTG"} = 1; $start_codon{"TTA"} = 1; $start_codon{"TTG"} = 1;
    }
    elsif ( $genetic_code == 5 ) {
        $code{"AGA"} = "S"; $code{"AGG"} = "S"; $code{"ATA"} = "M"; $code{"TGA"} = "W";
        $start_codon{"ATA"} = 1; $start_codon{"ATT"} = 1; $start_codon{"ATC"} = 1; $start_codon{"GTG"} = 1; $start_codon{"TTG"} = 1;
    }
    elsif ( $genetic_code == 6 ) {
        $code{"TAA"} = "Q"; $code{"TAG"} = "Q";
    }
    elsif ( $genetic_code == 9 ) {
        $code{"AAA"} = "N"; $code{"AGA"} = "S"; $code{"AGG"} = "S"; $code{"TGA"} = "W";
        $start_codon{"GTG"} = 1;
    }
    elsif ( $genetic_code == 10 ) {
        $code{"TGA"} = "C";
    }
    elsif ( $genetic_code == 11 ) {
        $start_codon{"ATA"} = 1; $start_codon{"ATT"} = 1; $start_codon{"ATC"} = 1; $start_codon{"GTG"} = 1; $start_codon{"CTG"} = 1; $start_codon{"TTG"} = 1;
    }
    elsif ( $genetic_code == 12 ) {
        $code{"CTG"} = "S"; $start_codon{"CTG"} = 1;
    }
    elsif ( $genetic_code == 13 ) {
        $code{"AGA"} = "G"; $code{"AGG"} = "G"; $code{"ATA"} = "M"; $code{"TGA"} = "W";
        $start_codon{"ATA"} = 1; $start_codon{"GTG"} = 1; $start_codon{"TTG"} = 1;
    }
    elsif ( $genetic_code == 14 ) {
        $code{"AAA"} = "N"; $code{"AGA"} = "S"; $code{"AGG"} = "S"; $code{"TAA"} = "Y"; $code{"TGA"} = "W";
    }
    elsif ( $genetic_code == 16 ) {
        $code{"TAG"} = "L";
    }
    elsif ( $genetic_code == 21 ) {
        $code{"TGA"} = "W"; $code{"ATA"} = "M"; $code{"AGA"} = "S"; $code{"AGG"} = "S"; $code{"AAA"} = "N";
        $start_codon{"GTG"} = 1;
    }
    elsif ( $genetic_code == 22 ) {
        $code{"TCA"} = "X"; $code{"TAG"} = "L";
    }
    elsif ( $genetic_code == 23 ) {
        $code{"TTA"} = "X";
        $start_codon{"ATT"} = 1; $start_codon{"GTG"} = 1;
    }
    elsif ( $genetic_code == 24 ) {
        $code{"AGA"} = "S"; $code{"AGG"} = "K"; $code{"TGA"} = "W";
        $start_codon{"GTG"} = 1; $start_codon{"CTG"} = 1; $start_codon{"TTG"} = 1;
    }
    elsif ( $genetic_code == 25 ) {
        $code{"TGA"} = "G";
        $start_codon{"GTG"} = 1; $start_codon{"TTG"} = 1;
    }
    elsif ( $genetic_code == 26 ) {
        $code{"CTG"} = "A";
        $start_codon{"GTG"} = 1; $start_codon{"TTG"} = 1;
    }
    elsif ( $genetic_code == 27 ) {
        $code{"TAG"} = "Q"; $code{"TAA"} = "Q";
    }
    elsif ( $genetic_code == 29 ) {
        $code{"TAA"} = "Y"; $code{"TAG"} = "Y";
    }
    elsif ( $genetic_code == 30 ) {
        $code{"TAA"} = "E"; $code{"TAG"} = "E";
    }
    elsif ( $genetic_code == 31 ) {
        $code{"TGA"} = "W";
    }
    elsif ( $genetic_code == 33 ) {
        $code{"TAA"} = "Y"; $code{"TGA"} = "Y"; $code{"AGA"} = "S"; $code{"AGG"} = "K";
    }

    my %stop_codon;
    foreach ( keys %code ) {
        $stop_codon{$_} = 1 if $code{$_} eq "X";
    }

    return (\%code, \%start_codon, \%stop_codon);
}


sub get_usage_english {
my $usage = <<USAGE;
Usage:
    $0 [options] genome.fasta > LongReads_prediction.gff3

    This program uses long-read RNA-Seq data (PacBio HiFi, Nanopore cDNA, or Nanopore dRNA) to predict
    gene models on a whole genome sequence, and outputs GFF3 format results to standard output.

    The pipeline process:
    (a) First, align long reads to the reference genome using minimap2, producing a sorted BAM file.
    (b) Then, use IsoQuant to discover transcript models from the long-read alignments. Optionally,
        short-read (Illumina) BAM can be provided for splice junction correction.
    (c) Then, use SQANTI3 for quality control and filtering of discovered transcripts, removing
        artifacts and low-quality isoforms.
    (d) Then, use TransDecoder to predict ORFs on the filtered transcripts and map them back to
        genome coordinates.
    (e) Finally, post-process the gene models: remove redundancy, optionally fill incomplete models
        using homolog gene models, force-fill ends of incomplete models, classify gene models into
        4 quality tiers, and output the final GFF3.

    Gene model classes:
    A (Excellent): Complete gene models with ORF occupying >= 50% of transcript sequence.
    B (Good): Other complete gene models.
    C (Fair): Gene models completed by forced end-filling.
    D (Poor): Gene models that remain incomplete after forced end-filling.

Parameters:
[INPUT]
    --long_reads <string>    (required)
    FLNC (full-length non-chimeric) FASTQ or BAM files from long-read RNA-Seq.
    Multiple files can be comma-separated.

    --long_read_type <string>    default: pacbio_hifi
    Type of long reads. Must be one of: pacbio_hifi, nanopore_cdna, nanopore_drna.
    This determines minimap2 alignment parameters and IsoQuant data type.

    --illumina_bam <string>    default: None
    Optional short-read (Illumina) BAM file for splice junction correction in IsoQuant.

    --strand_specific    default: None
    Flag indicating that the long-read data is strand-specific.

    --config <string>    default: None
    Path to a parameter configuration file for tuning software parameters.

    --homolog_gene_models <string>    default: None
    GFF3 file of gene models predicted from homologous proteins, used to fill
    incomplete gene model ends.

[OUTPUT]
    --help    default: None
    Display this help and exit.

    --tmp_dir <string>    default: LongReads_prediction_tmp
    Path to temporary working directory.

    --output_alignment_GFF3 <string>    default: None
    Output path for the transcript-to-genome alignment GFF3 file.

    --output_raw_GFF3 <string>    default: None
    Output path for the raw (before forced end-filling) gene model GFF3 file.

    --intron_info_out <string>    default: None
    Output path for intron information file (tab-separated: transcript_region,
    chromosome, strand, intron_start, intron_end, intron_depth, median_depth).

    --base_depth_out <string>    default: None
    Output path for per-base sequencing depth file (tab-separated: chromosome,
    strand, position, depth).

[THRESHOLD]
    --genetic_code <int>    default: 1
    NCBI genetic code table number. See: https://www.ncbi.nlm.nih.gov/Taxonomy/Utils/wprintgc.cgi

[PERFORMANCE]
    --cpu <int>    default: 4
    Number of CPU threads.

Dependencies:
    minimap2, samtools, isoquant.py, sqanti3_qc.py, sqanti3_filter.py, gffread,
    TransDecoder.LongOrfs, TransDecoder.Predict, TransDecoder.Util.*

USAGE

return $usage;
}
