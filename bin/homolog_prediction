#!/usr/bin/env perl

use strict;
use Getopt::Long;
use Cwd qw/abs_path getcwd cwd/;
use File::Basename;

my $command_line = "$0 " . join(" ", @ARGV);
my $bin_path = dirname($0);
my $software_dir = $bin_path; $software_dir =~ s/\/bin$//;

my $usage_english = &get_usage_english();
if (@ARGV==0){die $usage_english}

my ($out_prefix, $cpu, $identity, $homolog_coverage, $method, $genetic_code, $tmp_dir, $output_raw_GFF3, $output_alignment_GFF3, $outs, $min_coverage, $min_identity, $help, $chinese_help);
my (@cmdString, $cmdString);
GetOptions(
    "out_prefix:s" => \$out_prefix,
    "cpu:i" => \$cpu,
    "identity:f" => \$identity,
    "homolog_coverage:f" => \$homolog_coverage,
    "method:s" => \$method,
    "genetic_code:i" => \$genetic_code,
    "tmp_dir:s" => \$tmp_dir,
    "output_raw_GFF3:s" => \$output_raw_GFF3,
    "output_alignment_GFF3:s" => \$output_alignment_GFF3,
    "outs:f" => \$outs,
    "min_coverage:f" => \$min_coverage,
    "min_identity:f" => \$min_identity,
    "help" => \$help,
    "chinese_help" => \$chinese_help,
    # Accept but ignore legacy parameters for backward compatibility
    "evalue:f" => \my $_evalue,
    "max_hits_num_per_match_region:i" => \my $_max_hits,
    "max_hit_num_per_single_species:i" => \my $_max_hit_species,
    "threshod_ratio_of_intron_Supported_times:f" => \my $_threshold_ratio,
    "max_alignment_num_for_each_gene_region:i" => \my $_max_align,
    "put_massive_temporary_data_into_memory!" => \my $_mem,
);
if ( $chinese_help ) { die $usage_english }
if ( $help ) { die $usage_english }

# Print the running command on STDERR.
my $pwd = `pwd`; chomp($pwd);
my $programe_name = basename($0);
print STDERR "\n#################### $programe_name | Start ####################\n";
print STDERR "PWD: $pwd\n" . (localtime) . ": CMD: " . $command_line . "\n";
print STDERR "============================================\n";

########### Parse parameters #################
# Convert to absolute paths
$output_alignment_GFF3 = abs_path($output_alignment_GFF3) if $output_alignment_GFF3;
$output_raw_GFF3 = abs_path($output_raw_GFF3) if $output_raw_GFF3;
my $input_protein = abs_path($ARGV[0]);
my $input_genome = abs_path($ARGV[1]);
die "Error: protein file $ARGV[0] does not exist.\n" unless -e $input_protein;
die "Error: genome file $ARGV[1] does not exist.\n" unless -e $input_genome;

# Set default values
$out_prefix ||= "out";
$cpu ||= 8;
$identity ||= 0.2;
$homolog_coverage ||= 0.3;
$method ||= "miniprot";
$genetic_code ||= 1;
$outs ||= 0.95;
$min_coverage ||= 0.4;
$min_identity ||= 0.2;

# Validate method
foreach ( split /,/, $method ) {
    unless ( $_ eq "miniprot" ) {
        warn "Warning: The method $_ is not supported. Only 'miniprot' is supported.\n";
    }
}

# Prepare temporary directory
my $date = `date +%Y%m%d%H%M%S`; chomp($date);
$tmp_dir ||= "tmp_$date$$";
$tmp_dir = abs_path($tmp_dir);
mkdir $tmp_dir unless -e $tmp_dir;
###############################


# 1. Run miniprot to align protein sequences to the genome.
print STDERR "1. Aligning protein sequences to genome using miniprot.\n";
chdir $tmp_dir;
$pwd = `pwd`; chomp($pwd);
print STDERR "PWD: $pwd\n";

$cmdString = "miniprot -t $cpu --gff --outs=$outs --aln $input_genome $input_protein > miniprot_raw.gff 2> miniprot.log";
&execute_cmds($cmdString, "a.miniprot.ok");

# 2. Convert miniprot GFF3 output to GETA GFF3 format, classify gene models, and remove redundancy.
print STDERR "2. Converting miniprot output to GETA GFF3 format and classifying gene models.\n";

my @cmdString;
push @cmdString, "$bin_path/miniprot_GFF3_to_GETA_GFF3.pl --genetic_code $genetic_code --min_coverage $min_coverage --min_identity $min_identity --out_prefix $out_prefix --tmp_dir $tmp_dir/b.convertGFF3 $input_genome $input_protein $tmp_dir/miniprot_raw.gff > $tmp_dir/$out_prefix.geneModels.gff3 2> $tmp_dir/b.convertGFF3.log";

if ( $output_alignment_GFF3 ) {
    push @cmdString, "cp $tmp_dir/b.convertGFF3/homolog_alignment.gff3 $output_alignment_GFF3";
}

if ( $output_raw_GFF3 ) {
    push @cmdString, "$bin_path/GFF3_merging_and_removing_redundancy_Parallel --cpu $cpu --first_file_score 0.0 $input_genome $tmp_dir/b.convertGFF3/homolog_prediction.raw.gff3 > $tmp_dir/homolog_raw_merged.gff3 2> $tmp_dir/b.GFF3_merging.log";
    push @cmdString, "$bin_path/GFF3Clear --genome $input_genome --gene_prefix homolog $tmp_dir/homolog_raw_merged.gff3 > $output_raw_GFF3 2> /dev/null";
    push @cmdString, "rm -f $tmp_dir/homolog_raw_merged.gff3";
}

&execute_cmds(@cmdString, "b.convertGFF3.ok");

# 3. Filter gene models and output final results.
print STDERR "3. Filtering gene models and outputting final results.\n";

open IN, "$tmp_dir/$out_prefix.geneModels.gff3" or die "Can not open file $tmp_dir/$out_prefix.geneModels.gff3, $!";
open OUTF, ">", "$tmp_dir/$out_prefix.geneModels.filter.gff3" or die "Can not create file $tmp_dir/$out_prefix.geneModels.filter.gff3, $!";
my ($numA, $numB, $numC, $numD) = (0, 0, 0, 0);
$/ = "\n\n";
while (<IN>) {
    if (m/Type=excellent_gene_models_predicted_by_homolog/) {
        print OUTF $_; $numA ++;
    }
    elsif (m/Type=good_gene_models_predicted_by_homolog/) {
        print OUTF $_; $numB ++;
    }
    elsif (m/Type=fair_gene_models_predicted_by_homolog/) {
        print OUTF $_; $numC ++;
    }
    elsif (m/Type=poor_gene_models_predicted_by_homolog/) {
        print OUTF $_; $numD ++;
    }
}
close IN; close OUTF;
$/ = "\n";
my $total = $numA + $numB + $numC + $numD;

$cmdString = "$bin_path/GFF3Clear --genome $input_genome --no_attr_add --gene_prefix homolog $tmp_dir/$out_prefix.geneModels.filter.gff3 2> $tmp_dir/c.GFF3Clear.log";
print STDERR (localtime) . ": CMD: $cmdString\n";
system("$cmdString") == 0 or die "failed to execute: $cmdString\n";

print STDERR "\nFinally, total $total gene models were divided into 4 classes : A, $numA; B, $numB; C, $numC; D, $numD. \nPredicted by miniprot, $total\n\n";


# Subroutine: execute commands with .ok checkpoint files
sub execute_cmds {
    my $ok_file = pop @_;

    if ( -e $ok_file ) {
        foreach ( @_ ) {
            print STDERR "CMD(Skipped): $_\n";
        }
    }
    else {
        foreach ( @_ ) {
            print STDERR (localtime) . ": CMD: $_\n";
            system($_) == 0 or die "failed to execute: $_\n";
        }
        open OKOUT, ">", "$ok_file" or die $!; close OKOUT;
    }

    return 1;
}


sub get_usage_english {
my $usage = <<USAGE;
Usage:
    $0 [options] homolog_proteins.fasta genome_seq.fasta > out.gff3

    This program uses homologous protein sequences from closely related species to
    predict gene models on a target genome, using miniprot for protein-to-genome alignment.
    Results are output in GFF3 format to STDOUT.

    Gene models are classified into four categories:
    A (excellent): coverage >= 80%, identity >= 60%, with both start and stop codons matching.
    B (good):      coverage >= 60%, identity >= 40%, complete gene model.
    C (fair):      coverage >= min_coverage, identity >= min_identity, complete gene model.
    D (poor):      below the minimum thresholds or incomplete gene models.

    Pipeline steps:
    1. Run miniprot to align homologous proteins to the genome.
    2. Convert miniprot GFF output to GETA GFF3 format with gene classification.
    3. Filter gene models and remove redundancy.

    --out_prefix <string>    default: out
    Set output file prefix.

    --cpu <int>    default: 8
    Number of threads for miniprot.

    --method <string>    default: miniprot
    Alignment method. Currently only 'miniprot' is supported.

    --genetic_code <int>    default: 1
    Genetic code table number (NCBI). See: https://www.ncbi.nlm.nih.gov/Taxonomy/Utils/wprintgc.cgi

    --outs <float>    default: 0.95
    Miniprot output score threshold. Keep alignments scoring >= this fraction of the best.

    --min_coverage <float>    default: 0.4
    Minimum protein coverage to keep a gene model (for fair class).

    --min_identity <float>    default: 0.2
    Minimum alignment identity to keep a gene model (for fair class).

    --identity <float>    default: 0.2
    Kept for backward compatibility (alias for --min_identity in filtering context).

    --homolog_coverage <float>    default: 0.3
    Kept for backward compatibility.

    --tmp_dir <string>    default: tmp_\$date\$pid
    Temporary directory for intermediate files.

    --output_raw_GFF3 <string>    default: None
    Output raw GFF3 file with all gene models before filtering (original miniprot predictions).

    --output_alignment_GFF3 <string>    default: None
    Output a GFF3-format alignment file showing protein-to-genome alignments.

    --help    default: None
    Display this help and exit.

    This program requires: miniprot, and companion scripts miniprot_GFF3_to_GETA_GFF3.pl,
    GFF3Clear, GFF3_merging_and_removing_redundancy_Parallel in the same bin directory.

USAGE

return $usage;
}
